{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://pawelwielga.dihor.pl",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:encoding && vite build && node ./scripts/generate-sitemap.mjs",
    "postbuild": "node ./scripts/generate-sitemap.mjs",
    "generate:sitemap": "node ./scripts/generate-sitemap.mjs",
    "check:encoding": "node ./scripts/check-encoding.mjs",
    "lint": "npm run check:encoding && eslint .",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:status": "git config --get core.hooksPath",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "react-typed": "^2.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vite": "^8.0.0",
    "vite-plugin-imagemin": "^0.6.1"
  },
  "overrides": {
    "flatted": "^3.4.0"
  }
}
